@using Sandbox;
@using Sandbox.UI;
@inherits PanelComponent
@namespace Undercooked.UI.PlateWorldPanel

<root>
    @if (plate.Ingredients.Count > 0)
    {
        <PlateIngredients Ingredients="@plate.Ingredients" />
    }
</root>

@code {
    [Property]
    public PlateItem plate;

    protected override int BuildHash() => System.HashCode.Combine(plate.Ingredients.Count);
}