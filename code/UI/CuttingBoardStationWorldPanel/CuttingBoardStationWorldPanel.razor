@using Sandbox;
@using Sandbox.UI;
@inherits PanelComponent
@namespace Undercooked.UI.CuttingBoardWorldPanel

<root>
    @if (HasChoppableIngredient)
    {
        <ProgressBar Progress="@ChopProgress" />
    }
</root>

@code {
    [Property]
    public CuttingBoardStation station;

    private bool HasChoppableIngredient => station.StoredPickable is IngredientItem { Choppable: true };

    private float ChopProgress
    {
        get
        {
            if (station.StoredPickable is not IngredientItem ingredient)
                return 0f;

            return ingredient.ChopProgress;
        }
    }

    protected override int BuildHash() => System.HashCode.Combine(ChopProgress, HasChoppableIngredient);
}