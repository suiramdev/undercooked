@using Sandbox;
@using Sandbox.UI;
@using System;
@inherits Panel
@namespace Undercooked.UI.HUD

<root>
    <div class="order">
        <div class="progress-bar">
            <div class="progress-bar-fill" style="width: @(Progress * 100)%; background: @ProgressBarColor"></div>
        </div>
        <Image class="icon" src="@Recipe.Icon.ResourcePath" />
    </div>
    <div class="steps-ribbon">
        @foreach (var ingredient in Recipe.RequiredIngredients)
        {
            <OrderIngredientSteps Ingredient="@ingredient" />
        }
    </div>
</root>

@code {
    [Parameter]
    public RecipeResource Recipe { get; set; }

    [Parameter]
    public float PlacedAt { get; set; }

    private float Progress
    {
        get
        {
            float timeout = LevelConfig.Instance.OrderTimeout;
            float remaining = timeout - (Time.Now - PlacedAt);
            return Math.Max(remaining, 0) / timeout;
        }
    }

    /// <summary>Green when time is plentiful, red when time is critical.</summary>
    private string ProgressBarColor
    {
        get
        {
            float t = Math.Clamp(Progress, 0f, 1f);
            int r = (int)(124 + (220 - 124) * (1f - t));
            int g = (int)(207 + (38 - 207) * (1f - t));
            int b = (int)(0 + (38 - 0) * (1f - t));
            return $"rgb({r},{g},{b})";
        }
    }

    protected override int BuildHash() => System.HashCode.Combine(Recipe, Progress);
}