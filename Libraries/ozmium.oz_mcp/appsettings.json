{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "Console": {
      "IncludeScopes": false,
      "TimestampFormat": "HH:mm:ss "
    }
  },
  "WebSocket": {
    "Url": "http://+:8080",
    "Path": "/ws"
  },
  "AllowedHosts": "*"
}